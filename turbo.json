{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "^dev"
      ]
    },
    "start": {
      "persistent": true
    },
    "format": {
      "dependsOn": [
        "^format"
      ]
    },
    "pm2": {
      "dependsOn": [
        "^pm2"
      ]
    }
  }
}