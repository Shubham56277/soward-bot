# Soward Bot - Production Environment Variables
# Copy this file to /opt/soward-bot/.env and fill in real values.
# NEVER commit real credentials to the repository.

# Discord
DISCORD_APP_TOKEN=your_discord_bot_token
DISCORD_APP_CLIENT_ID=your_client_id
DISCORD_APP_CLIENT_SECRET=your_client_secret
GUILD_ID=
DEVELOPER_IDS=["your_user_id"]
PREFIX=!

# Database
DATABASE_URI=postgresql://soward:password@localhost:5432/soward

# Redis
REDIS_URL=redis://localhost:6380/0

# Lavalink nodes (JSON array)
NODES=[{"id":"main","host":"127.0.0.1","port":2333,"authorization":"your_lavalink_password","secure":false}]

# Environment
NODE_ENV=production

# Sentry (optional)
SENTRY_DSN=

# API / URLs
NEXT_PUBLIC_BASE_URL=http://localhost:5173
IMAGIFY_API_URL=
MEDIA_PROXY_URL=http://127.0.0.1:5173

# Payment (optional)
OXAPAY_MERCHANT_KEY=

# Webhooks (optional)
# COMMAND_LOG_WEBHOOK_URL=
# GUILD_CREATE_WEBHOOK_URL=
# GUILD_DELETE_WEBHOOK_URL=
# NO_PREFIX_WEBHOOK_URL=
# PREMIUM_WEBHOOK_URL=
# SHARD_WEBHOOK_URL=

# AI Configuration
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
HUGGINGFACE_TOKEN=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct
AI_TIMEOUT_SECONDS=8
AI_MAX_HISTORY=12
AI_MAX_OUTPUT_TOKENS=700
AI_RACE_MODE=false
AI_SESSION_TTL_SECONDS=21600
AI_USER_REQUESTS_PER_MINUTE=5
AI_GUILD_REQUESTS_PER_MINUTE=60
AI_MAX_CONCURRENCY=20
AI_RESPONSE_CACHE_SECONDS=600

# Health server (bot internal)
HEALTH_PORT=9090
