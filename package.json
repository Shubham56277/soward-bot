{
  "name": "repo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo start",
    "bot:build": "yarn workspace bot build",
    "bot:dev": "yarn workspace bot dev",
    "bot:start": "yarn workspace bot start",
    "bot:pm2": "yarn workspace bot pm2",
    "bot:deploy": "bash deploy/scripts/deploy.sh",
    "bot:launch": "bash scripts/start-bot.sh",
    "bot:health": "curl -sf http://127.0.0.1:9090/health | node -e \"process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.stringify(JSON.parse(d),null,2)))\"",
    "bot:diagnose": "bash deploy/scripts/diagnose-server.sh",
    "clean": "turbo clean",
    "clean:all": "turbo clean:all",
    "format": "turbo format",
    "lint": "turbo lint",
    "pm2": "turbo pm2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/node": "^24.13.3",
    "turbo": "^2.10.5",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.9.0",
    "@sentry/cli": "^3.6.1",
    "@sentry/node": "^10.67.0",
    "tsup": "^8.5.1"
  },
  "packageManager": "yarn@1.22.22",
  "resolutions": {
    "tsup/esbuild": "0.28.1"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
